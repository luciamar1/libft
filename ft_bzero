#include <unistd.h>
#include <stdio.h>
#include <string.h>

void    *ft_bzero(void *s, size_t n)
{
        size_t  i;

        i = 0;
        while (i < n)
                ((char *)s)[i++] = 0;
        return (s);
}

int     main(void)

{
        char    s[20] = "hola soy super guay\n";
        ft_bzero(s, 5);
        write(1, &s[4], 1);
        printf("%s\n", s);
        write(1, &s[6], 1);
        return (0);
}
